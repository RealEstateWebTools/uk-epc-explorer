# JS/CSS source files — always revalidate (no bundler = no fingerprinted filenames)
/src/*
  Cache-Control: no-cache, must-revalidate

# HTML entry point — same, since it references the source files directly
/index.html
  Cache-Control: no-cache, must-revalidate

# Static assets can be cached aggressively
/favicon.*
  Cache-Control: public, max-age=31536000, immutable
